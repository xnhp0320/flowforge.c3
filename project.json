{
  "langrev": "1",
  "warnings": [ "no-unused" ],
  "dependency-search-paths": [ "lib" ],
  "dependencies": [ ],
  "authors": [ "FlowForge contributors" ],
  "version": "0.1.0",
  "sources": [ "src/**" ],
  "test-sources": [ "test/**" ],
  "build-dir": "build",
  "output": "build",
  "c-sources": [ "csrc/dpdk_shim.c" ],
  "c-include-dirs": [ "/opt/dpdk/include", "csrc" ],
  "cflags": "-I/opt/dpdk/include -Icsrc -include rte_config.h -march=corei7 -mrtm",
  "linker": "cc",
  "linker-search-paths": [ "/opt/dpdk/lib/x86_64-linux-gnu" ],
  "link-args": [
    "-Wl,-rpath,/opt/dpdk/lib/x86_64-linux-gnu",
    "-Wl,--no-as-needed",
    "-lrte_bus_vdev",
    "-lrte_bus_pci",
    "-lrte_net_tap",
    "-lrte_mempool_ring",
    "-lrte_ethdev",
    "-lrte_mbuf",
    "-lrte_mempool",
    "-lrte_ring",
    "-lrte_net",
    "-lrte_meter",
    "-lrte_pci",
    "-lrte_hash",
    "-lrte_lpm",
    "-lrte_stack",
    "-lrte_gso",
    "-lrte_cmdline",
    "-lrte_rcu",
    "-lrte_telemetry",
    "-lrte_argparse",
    "-lrte_kvargs",
    "-lrte_eal",
    "-lrte_log",
    "-Wl,--as-needed",
    "-lpthread",
    "-lm",
    "-ldl",
    "-lnuma"
  ],
  "targets": {
    "ffg": {
      "type": "executable"
    }
  },
  "cpu": "generic",
  "opt": "O0"
}
